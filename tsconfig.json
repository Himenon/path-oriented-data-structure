{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": false,
		"skipLibCheck": true,
		"sourceMap": true,
		"target": "es2022",
		"lib": ["dom", "es2023"],
		"types": ["node"],
		"rootDir": ".",
		"strict": true,
		"resolveJsonModule": true
	}
}
